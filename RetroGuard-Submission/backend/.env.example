# Copy this to backend/.env for local Postgres development.
# Leave unset to fall back to SQLite (./retroguard.db).

# Local docker-compose Postgres:
DATABASE_URL=postgresql+psycopg2://retroguard:retroguard@localhost:5432/retroguard

# Production (NHAI) would look like:
# DATABASE_URL=postgresql+psycopg2://USER:PASS@HOST:5432/retroguard?sslmode=require

# Seed synthetic demo data on startup. Set to 0 for a clean DB (real imports only).
SEED_DEMO=1

# JWT secret for staff bearer-token auth. MUST be rotated in production.
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-a-long-random-string

# CORS allowed origins (comma-separated). Defaults to localhost dev ports when unset.
# Dev:
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3005
# Prod example:
# CORS_ALLOWED_ORIGINS=https://retroguard.nhai.gov.in,https://api.retroguard.nhai.gov.in
