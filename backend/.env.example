# Copy this to backend/.env for local Postgres development.
# Leave unset to fall back to SQLite (./retroguard.db).

# Local docker-compose Postgres:
DATABASE_URL=postgresql+psycopg2://retroguard:retroguard@localhost:5432/retroguard

# Production (NHAI) would look like:
# DATABASE_URL=postgresql+psycopg2://USER:PASS@HOST:5432/retroguard?sslmode=require

# Seed synthetic demo data on startup. Set to 0 for a clean DB (real imports only).
SEED_DEMO=1
